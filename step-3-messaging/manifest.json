{
  "manifest_version": 3,
  "name": "LeetSync — Step 3",
  "version": "0.0.3",
  "description": "Content script talks to a background service worker.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "LeetSync"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
