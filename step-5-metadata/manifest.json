{
  "manifest_version": 3,
  "name": "NeetSync — Step 5",
  "version": "0.0.5",
  "description": "Worker fetches problem metadata (title, difficulty, tags) via LeetCode GraphQL.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "NeetSync"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://leetcode.com/*"],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["interceptor.js"],
      "matches": ["https://leetcode.com/*"]
    }
  ]
}
