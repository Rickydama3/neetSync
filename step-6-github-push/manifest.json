{
  "manifest_version": 3,
  "name": "NeetSync — Step 6",
  "version": "0.0.6",
  "description": "Auto-pushes accepted solutions to GitHub as study notes.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "NeetSync"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://api.github.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["interceptor.js"],
      "matches": ["https://leetcode.com/*"]
    }
  ]
}
